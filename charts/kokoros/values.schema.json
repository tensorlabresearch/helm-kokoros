{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["image", "gpu", "persistence", "modelPreload", "kokoros"],
  "properties": {
    "image": {
      "type": "object",
      "required": ["repository", "tag"],
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string" }
      }
    },
    "gpu": {
      "type": "object",
      "required": ["enabled", "count", "resourceKey"],
      "properties": {
        "enabled": { "type": "boolean" },
        "count": { "type": ["integer", "string"] },
        "resourceKey": { "type": "string", "minLength": 1 }
      }
    },
    "persistence": {
      "type": "object",
      "required": ["models"],
      "properties": {
        "models": {
          "type": "object",
          "required": ["enabled", "size", "storageClass"],
          "properties": {
            "enabled": { "type": "boolean" },
            "existingClaim": { "type": "string" },
            "size": { "type": "string", "minLength": 1 },
            "storageClass": { "type": "string" },
            "accessModes": {
              "type": "array",
              "items": { "type": "string" }
            },
            "mountPath": { "type": "string", "minLength": 1 },
            "readOnly": { "type": "boolean" }
          }
        }
      }
    },
    "modelPreload": {
      "type": "object",
      "required": ["enabled", "continueOnError", "items"],
      "properties": {
        "enabled": { "type": "boolean" },
        "continueOnError": { "type": "boolean" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "url", "filename", "targetSubdir", "sha256"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "url": { "type": "string", "minLength": 1 },
              "filename": { "type": "string", "minLength": 1 },
              "targetSubdir": { "type": "string" },
              "sha256": { "type": "string" }
            }
          }
        }
      }
    },
    "kokoros": {
      "type": "object",
      "required": ["activeBundle", "bundles"],
      "properties": {
        "activeBundle": { "type": "string", "minLength": 1 },
        "instances": { "type": "integer", "minimum": 1 },
        "bundles": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "modelPath", "voicesPath", "preload"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "modelPath": { "type": "string", "minLength": 1 },
              "voicesPath": { "type": "string", "minLength": 1 },
              "preload": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["id", "url", "filename", "targetSubdir", "sha256"],
                  "properties": {
                    "id": { "type": "string", "minLength": 1 },
                    "url": { "type": "string", "minLength": 1 },
                    "filename": { "type": "string", "minLength": 1 },
                    "targetSubdir": { "type": "string" },
                    "sha256": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
